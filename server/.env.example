# Elix AI Backend Configuration
NODE_ENV=production
PORT=3001
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
# Used when the client sends a photo (vision). Falls back to google/gemini-2.0-flash-exp:free if unset.
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-exp:free
# Comma-separated list of allowed frontend origins (set this on Render)
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=https://your-app.vercel.app
